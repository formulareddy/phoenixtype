# OpenRouter API key (required for AI Assistant)
# Get a free key at https://openrouter.ai/keys
# VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional: override the default model
# VITE_OPENROUTER_MODEL=openrouter/free

# Firebase Authentication (required for sign up / sign in)
# Get these from your Firebase project → Project Settings → General → Your apps → Web app
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
